# Ports for containerized MCP servers
FILESYSTEM_MCP_PORT=3333
GOOGLE_SEARCH_MCP_PORT=3333
MEDIA_TOOLS_MCP_PORT=4444
PLAYWRIGHT_MCP_PORT=3335
# PDF static HTTP (tasks/pdf docker-compose): host port -> container 18080 (Playwright uses in-network URL)
PDF_HTTP_PORT=18080
# Inside Docker network, Playwright hits task-env:18080; runner rewrites file:///workspace/... in task.yaml.
# Change only if you change the listener port in compose (keep in sync with http.server).
# MCPU_MM_PDF_HTTP_HOST=task-env
# MCPU_MM_PDF_HTTP_INTERNAL_PORT=18080

# Proxy (same pattern as online_video/search_qa — YouTube stack)
MCPU_MM_HTTP_PROXY=http://host.docker.internal:7890
MCPU_MM_HTTPS_PROXY=http://host.docker.internal:7890
MCPU_MM_ALL_PROXY=socks5://host.docker.internal:7890
MCPU_MM_NO_PROXY=localhost,127.0.0.1,host.docker.internal

# google-search MCP uses SerpAPI (see MCP-Universe google_search server)
SERP_API_KEY=
# Optional alias; pdf scholar compose maps this into SERP_API_KEY if SERP_API_KEY is empty
# SERPER_API_KEY=

# Gateway address for MCP-Universe Gateway
MCP_GATEWAY_ADDRESS=http://127.0.0.1:3333